# .env.example — Variables d'environnement
# Copier en .env et adapter les valeurs
# NE JAMAIS COMMITTER le fichier .env

# ── Base de données ──────────────────────────────────────────
POSTGRES_ROOT_PASSWORD=ChangeMe_Root_2024!
DB_PASSWORD=ChangeMe_App_2024!
DB_NAME=appdb
DB_USER=appuser

# ── Backend ──────────────────────────────────────────────────
SECRET_KEY=your-very-long-random-secret-key-here-change-me

# ── AWS — IPs privées des EC2 (à remplir après déploiement) ──
WEB_PRIVATE_IP=10.0.1.10
BACKEND_PRIVATE_IP=10.0.2.10
DB_PRIVATE_IP=10.0.3.10
